/**
 * =====================================================
 * ⚙️ CONFIGURAÇÃO
 * =====================================================
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * =====================================================
 * 🏢 COMPANY (MULTI-TENANT)
 * =====================================================
 */
model Company {
  id   String @id @default(uuid())
  name String

  memberships Membership[]
  posts       Post[]
  invites     Invite[]

  createdAt DateTime @default(now())

  @@index([name])
}

/**
 * =====================================================
 * 👤 USER
 * =====================================================
 */
model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  password String?

  memberships Membership[]

  posts         Post[]
  permissions   UserPermission[]
  notifications Notification[]
  comments      Comment[]
  audits        AuditLog[]
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())

  @@index([email])
}

/**
 * =====================================================
 * 🔗 MEMBERSHIP
 * =====================================================
 */
model Membership {
  id        String @id @default(cuid())
  userId    String
  companyId String
  roleId    String

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])

  lastReadAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
}

/**
 * =====================================================
 * 🔐 RBAC
 * =====================================================
 */
model Role {
  id   String @id @default(cuid())
  name String @unique

  permissions RolePermission[]
  memberships Membership[]
  invites     Invite[]

  createdAt DateTime @default(now())
}

model Permission {
  id   String @id @default(cuid())
  name String @unique

  roles           RolePermission[]
  userPermissions UserPermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model UserPermission {
  id           String @id @default(uuid())
  userId       String
  companyId    String
  permissionId String

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@index([userId, companyId])
}

/**
 * =====================================================
 * 📝 POSTS
 * =====================================================
 */
model Post {
  id       Int     @id @default(autoincrement())
  title    String
  content  String
  imageUrl String?

  status PostStatus @default(DRAFT)

  authorId String
  author   User @relation(fields: [authorId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  scheduledDate DateTime?

  approvedBy String?
  approvedAt DateTime?

  comments Comment[]
  audits   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * =====================================================
 * 📊 STATUS
 * =====================================================
 */
enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  APPROVED
  REJECTED
}

/**
 * =====================================================
 * 🔔 NOTIFICAÇÕES
 * =====================================================
 */
model Notification {
  id      String  @id @default(uuid())
  userId  String
  message String
  read    Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 💬 COMMENTS
 * =====================================================
 */
model Comment {
  id      Int    @id @default(autoincrement())
  content String

  postId Int
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 🧾 AUDIT LOG
 * =====================================================
 */
model AuditLog {
  id     Int    @id @default(autoincrement())
  action String

  postId Int
  userId String

  meta Json?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 🔐 TOKENS
 * =====================================================
 */
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * =====================================================
 * ✉️ INVITES
 * =====================================================
 */
model Invite {
  id        String @id @default(uuid())
  email     String
  companyId String
  roleId    String
  token     String @unique

  expiresAt DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id])
}

/**
 * =====================================================
 * 📥 LEADS (CORRIGIDO E INTEGRADO)
 * =====================================================
 */
model Lead {
  id        String   @id @default(cuid())
  name      String
  company   String?
  document  String?   // CPF ou CNPJ
  email     String?
  whatsapp  String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([whatsapp])
}