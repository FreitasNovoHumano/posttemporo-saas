/**
 * =====================================================
 * ⚙️ CONFIGURAÇÃO
 * =====================================================
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * =====================================================
 * 🔐 ENUMS
 * =====================================================
 */

/**
 * 🔹 Roles por empresa (RBAC real)
 */
enum CompanyRole {
  ADMIN     // Controle total da empresa
  EDITOR    // Cria e edita conteúdos
  VIEWER    // Apenas visualização
}

/**
 * 🔹 Status do post
 */
enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  APPROVED
  REJECTED
}

/**
 * 🔹 Permissões granulares (opcional e avançado)
 */
enum Permission {
  CREATE_POST
  APPROVE_POST
  DELETE_POST
  VIEW_DASHBOARD
}

/**
 * =====================================================
 * 🏢 COMPANY (MULTI-TENANT)
 * =====================================================
 */

model Company {
  id   String @id @default(uuid())
  name String

  /**
   * 🔹 Relação com usuários via Membership
   */
  memberships Membership[]

  /**
   * 🔹 Dados isolados por empresa
   */
  posts Post[]

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 👤 USER
 * =====================================================
 */

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  password String

  /**
   * 🔥 MULTI-TENANT REAL
   * Um usuário pode estar em várias empresas
   */
  memberships Membership[]

  /**
   * 🔗 RELAÇÕES
   */
  posts         Post[]
  permissions   UserPermission[]
  notifications Notification[]
  comments      Comment[]
  audits        AuditLog[]
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 🔗 MEMBERSHIP (CORE DO MULTI-TENANT)
 * =====================================================
 */

model Membership {
  id        String @id @default(uuid())

  userId    String
  companyId String

  /**
   * 🔐 Role por empresa (RBAC)
   */
  role CompanyRole

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /**
   * 🚫 Evita duplicidade:
   * Um usuário não pode entrar duas vezes na mesma empresa
   */
  @@unique([userId, companyId])
}

/**
 * =====================================================
 * 🔐 PERMISSÕES GRANULARES
 * =====================================================
 */

model UserPermission {
  id         String     @id @default(uuid())
  userId     String
  companyId  String
  permission Permission

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /**
   * 💡 Permissão contextual por empresa
   */
  @@index([userId, companyId])
}

/**
 * =====================================================
 * 📝 POST (ISOLADO POR EMPRESA)
 * =====================================================
 */

model Post {
  id       Int    @id @default(autoincrement())
  title    String
  content  String
  imageUrl String?

  status PostStatus @default(DRAFT)

  /**
   * 👤 AUTOR
   */
  authorId String
  author   User @relation(fields: [authorId], references: [id])

  /**
   * 🏢 MULTI-TENANT (ISOLAMENTO)
   */
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /**
   * 📅 AGENDAMENTO
   */
  scheduledDate DateTime?

  /**
   * 🧾 APROVAÇÃO
   */
  approvedBy String?
  approvedAt DateTime?

  /**
   * 🔗 RELAÇÕES
   */
  comments Comment[]
  audits   AuditLog[]

  /**
   * ⏱️ CONTROLE
   */
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /**
   * 🔍 Performance
   */
  @@index([companyId])
}

/**
 * =====================================================
 * 🔔 NOTIFICAÇÕES
 * =====================================================
 */

model Notification {
  id      String  @id @default(uuid())
  userId  String
  message String
  read    Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 💬 COMENTÁRIOS
 * =====================================================
 */

model Comment {
  id      Int    @id @default(autoincrement())
  content String

  postId Int
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 🧾 AUDITORIA (LOG DE AÇÕES)
 * =====================================================
 */

model AuditLog {
  id     Int    @id @default(autoincrement())
  action String

  postId Int
  userId String

  meta Json? // 🔥 NOVO (opcional, muito poderoso)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 🔐 REFRESH TOKEN (AUTH)
 * =====================================================
 */

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}