generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  posts     Post[]   // 🔥 RELAÇÃO
  createdAt DateTime @default(now())
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  status      String   @default("Pendente")
  createdAt   DateTime @default(now())

  // 🔥 MULTI-TENANT
  userId Int
  user   User @relation(fields: [userId], references: [id])
}