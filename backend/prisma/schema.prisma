generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * =====================================================
 * 🔐 ENUMS
 * =====================================================
 */

enum Role {
  USER
  ADMIN
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  APPROVED
  REJECTED
}

enum Permission {
  CREATE_POST
  APPROVE_POST
  DELETE_POST
  VIEW_DASHBOARD
}

/**
 * =====================================================
 * 🏢 COMPANY (MULTI-TENANT)
 * =====================================================
 */

model Company {
  id   String @id @default(uuid())
  name String

  users User[]
  posts Post[]

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 👤 USER
 * =====================================================
 */

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  password String

  role Role @default(USER)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  posts         Post[]
  permissions   UserPermission[]
  notifications Notification[]
  comments      Comment[]
  audits        AuditLog[]

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 🔐 PERMISSÕES (RBAC)
 * =====================================================
 */

model UserPermission {
  id         String     @id @default(uuid())
  userId     String
  permission Permission

  user User @relation(fields: [userId], references: [id])
}

/**
 * =====================================================
 * 📝 POST
 * =====================================================
 */

model Post {
  id       Int     @id @default(autoincrement())
  title    String
  content  String
  imageUrl String?

  status PostStatus @default(DRAFT)

  /**
   * 👤 AUTOR
   */
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  /**
   * 🏢 MULTI-TENANT
   */
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  /**
   * 📅 AGENDAMENTO
   */
  scheduledDate DateTime?

  /**
   * 🧾 APROVAÇÃO
   */
  approvedBy String?
  approvedAt DateTime?

  /**
   * 🔗 RELAÇÕES
   */
  comments Comment[]
  audits   AuditLog[]

  /**
   * ⏱️ TEMPO
   */
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * =====================================================
 * 🔔 NOTIFICAÇÕES
 * =====================================================
 */

model Notification {
  id      String  @id @default(uuid())
  userId  String
  message String
  read    Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 💬 COMENTÁRIOS
 * =====================================================
 */

model Comment {
  id      Int    @id @default(autoincrement())
  content String

  postId Int
  userId String

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 🧾 AUDIT LOG
 * =====================================================
 */

model AuditLog {
  id     Int    @id @default(autoincrement())
  action String

  postId Int
  userId String

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
