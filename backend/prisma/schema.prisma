/**
 * =====================================================
 * ⚙️ CONFIGURAÇÃO
 * =====================================================
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * =====================================================
 * 🔐 ENUMS
 * =====================================================
 */

enum CompanyRole {
  ADMIN
  EDITOR
  VIEWER
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  APPROVED
  REJECTED
}

enum Permission {
  CREATE_POST
  APPROVE_POST
  DELETE_POST
  VIEW_DASHBOARD
}

/**
 * =====================================================
 * 🏢 COMPANY (MULTI-TENANT)
 * =====================================================
 */

model Company {
  id   String @id @default(uuid())
  name String

  memberships Membership[]
  posts       Post[]
  invites     Invite[] // 🔥 ESSENCIAL

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 👤 USER
 * =====================================================
 */

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  password String

  memberships Membership[]

  posts         Post[]
  permissions   UserPermission[]
  notifications Notification[]
  comments      Comment[]
  audits        AuditLog[]
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 🔗 MEMBERSHIP (CORE MULTI-TENANT)
 * =====================================================
 */

model Membership {
  id String @id @default(uuid())

  userId    String
  companyId String

  role CompanyRole

  // 🔥 Controle de leitura por empresa
  lastReadAt DateTime?

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}

/**
 * =====================================================
 * 🔐 PERMISSÕES GRANULARES
 * =====================================================
 */

model UserPermission {
  id         String     @id @default(uuid())
  userId     String
  companyId  String
  permission Permission

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, companyId])
}

/**
 * =====================================================
 * 📝 POST
 * =====================================================
 */

model Post {
  id       Int     @id @default(autoincrement())
  title    String
  content  String
  imageUrl String?

  status PostStatus @default(DRAFT)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  scheduledDate DateTime?

  approvedBy String?
  approvedAt DateTime?

  comments Comment[]
  audits   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

/**
 * =====================================================
 * 🔔 NOTIFICAÇÕES
 * =====================================================
 */

model Notification {
  id      String  @id @default(uuid())
  userId  String
  message String
  read    Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 💬 COMENTÁRIOS
 * =====================================================
 */

model Comment {
  id      Int    @id @default(autoincrement())
  content String

  postId Int
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 🧾 AUDIT LOG
 * =====================================================
 */

model AuditLog {
  id     Int    @id @default(autoincrement())
  action String

  postId Int
  userId String

  meta Json?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/**
 * =====================================================
 * 🔐 REFRESH TOKEN
 * =====================================================
 */

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * =====================================================
 * ✉️ INVITE
 * =====================================================
 */

model Invite {
  id        String      @id @default(uuid())
  email     String
  companyId String
  role      CompanyRole
  token     String      @unique

  expiresAt DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}
